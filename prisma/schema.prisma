generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  lastName String?
  role     Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  orders              Order[]
  measurementProfiles MeasurementProfile[]
}

enum Role {
  USER
  ADMIN
}

model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  status   OrderStatus @default(DRAFT)
  currency String      @default("usd")

  items OrderItem[]

  subtotalCents Int @default(0)
  totalCents    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id   String @id @default(uuid())
  name String

  items OrderItem[]
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  productType ProductType

  quantity Int @default(1)

  /// 👕 Talla estándar
  size SizeOption?

  /// 📏 Medidas personalizadas
  measurementProfileId String?
  measurementProfile   MeasurementProfile? @relation(fields: [measurementProfileId], references: [id])

  /// Congelar medidas al pagar
  measurementSnapshot Json?

  /// Configuración del configurador
  config Json

  notes String?

  /// Precio
  priceBreakdown Json?
  totalCents     Int   @default(0)

  createdAt DateTime @default(now())
}

enum SizeOption {
  XS
  S
  M
  L
  XL
}

model MeasurementProfile {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name String
  unit String @default("cm")

  entries    Measurement[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
}

model Measurement {
  id        String             @id @default(uuid())
  profileId String
  profile   MeasurementProfile @relation(fields: [profileId], references: [id])

  productType ProductType
  /// Medidas en JSON (flexible por prenda)
  data        Json

  createdAt DateTime @default(now())
}

enum ProductType {
  SHIRT
  PANTS
  JACKET
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELLED
  IN_PRODUCTION
  SHIPPED
}
